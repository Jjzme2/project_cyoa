# Firebase (Client SDK - safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (Server only - keep secret)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# AI (Vercel AI Gateway - OIDC auto-provisioned by vercel env pull)
# VERCEL_OIDC_TOKEN is auto-injected by Vercel; no manual key needed

# OpenRouter fallback (get free key at openrouter.ai)
OPENROUTER_API_KEY=

# Rate limiting (Upstash Redis via Vercel Marketplace)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Stripe (payments). REQUIRED in production: without a real STRIPE_SECRET_KEY the
# app only mocks checkout OUTSIDE production; in production a missing key makes
# payments fail cleanly (it never mocks). Set the price IDs to your live prices.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PREMIUM_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRICE_50=
NEXT_PUBLIC_STRIPE_PRICE_150=
NEXT_PUBLIC_STRIPE_PRICE_400=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Access control — comma-separated emails granted admin (content moderation,
# rating overrides). Bootstraps the first admin without running a script;
# use `npm run set-admin -- <email>` to persist the role as a custom claim.
ADMIN_EMAILS=

# Cron — shared secret for scheduled jobs (telemetry retention). Vercel sends it
# as `Authorization: Bearer <CRON_SECRET>`; generate a long random string.
CRON_SECRET=
# Days of raw telemetry events to keep before the daily prune (default 30).
TELEMETRY_RETENTION_DAYS=30
