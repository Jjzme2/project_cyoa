rules_version = '2';

// Chronicle Firestore rules.
//
// The app accesses Firestore exclusively through the Firebase Admin SDK on the
// server (which bypasses these rules). The ONLY direct client access is the
// co-op reading rooms feature, which subscribes to room docs in realtime.
//
// Therefore: rooms are readable by any signed-in user, all room writes go
// through the Admin SDK (server routes) and are denied to clients, and every
// other collection denies direct client access.
service cloud.firestore {
  match /databases/{database}/documents {

    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
